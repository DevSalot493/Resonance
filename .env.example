# Last.fm — register at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key_here
LASTFM_API_SECRET=your_api_secret_here
LASTFM_USER_AGENT=resonance/1.0

# MusicBrainz — no key needed, but user agent is mandatory
MB_USER_AGENT=resonance/1.0 (your@email.com)

# ListenBrainz — no auth needed
LB_BASE_URL=https://labs.api.listenbrainz.org

# PostgreSQL
POSTGRES_USER=music_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=resonance
DATABASE_URL=postgresql://music_user:changeme@localhost:5432/resonance

# Redis
REDIS_URL=redis://localhost:6379

# App
API_PORT=8000
LOG_LEVEL=INFO
SIMILARITY_THRESHOLD=0.15